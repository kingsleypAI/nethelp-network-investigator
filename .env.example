# ---- Backend ----
# Postgres in production. Omit to use the local SQLite fallback (sqlite:///./nexus.db).
DATABASE_URL=postgresql+psycopg2://nexus:nexus@localhost:5432/nexus

# Comma-separated origins allowed to call the API (the SPA).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Optional Claude enrichment ----
# The platform is fully functional without these. When enabled, Claude only
# rewrites the customer-facing explanation; the rules engine's verdict is final.
ENABLE_CLAUDE=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# ---- Frontend ----
# Where the SPA sends API calls. In Docker/nginx this is /api (proxied).
VITE_API_URL=/api
